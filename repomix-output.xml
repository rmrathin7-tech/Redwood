        }

        .login-card { animation: fadeUp 0.55s cubic-bezier(0.22,1,0.36,1) both; }

        .login-input {
          width: 100%; padding: 14px 16px;
          border-radius: 11px; border: 1px solid rgba(255,255,255,0.08);
