                          <button onClick={() => updateTemplateField(fi, 'options', (field.options || []).filter((_, idx) => idx !== oi))} style={{ background: 'none', border: 'none', color: T.danger, cursor: 'pointer', fontWeight: 'bold', fontSize: '0.9rem', lineHeight: 1 }}>×</button>
