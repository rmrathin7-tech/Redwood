        <input
          style={inp}
          type="text"
          value={blockConfig.imageWidth || '100%'}
          onChange={e => onChangeConfig({ imageWidth: e.target.value })}
          placeholder="e.g. 100% or 300px"
        />
      </div>
      <div style={{ flex: 1 }}>
        <label style={lbl}>Display Height</label>
        <input
          style={inp}
          type="text"
          value={blockConfig.imageHeight || '180px'}
