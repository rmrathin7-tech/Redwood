                <input style={{ ...inp, flex: 1 }} type="text" value={baseConfig.colWidths?.[idx] || ''} placeholder="Width (e.g. 30%, 150px)" onChange={e => { const newWidths = [...(baseConfig.colWidths || [])]; newWidths[idx] = e.target.value; onChangeConfig({ colWidths: newWidths }); }} />
