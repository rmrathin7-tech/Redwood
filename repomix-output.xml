                />
              ))}
            </div>
          </div>
        )}
      </main>

      {/* <-- 4. RENDER GLOBAL BOARD --> */}
      {isGlobalBoardOpen && (
        <GlobalBoard 
          projects={active} 
          isDark={isDark} 
