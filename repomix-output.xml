                onChangeArray(next);
              }}>
                {BLOCK_TYPES.filter(t => t.id !== 'repeating-block-set' && t.id !== 'conditional-switch').map(t => <option key={t.id} value={t.id}>{t.label}</option>)}
              </select>
              <button onClick={() => onChangeArray(blocksArray.filter((_, i) => i !== idx))}
