                    </label>
                  </div>
                )}
                <input style={{ ...inp, fontSize: '0.75rem', marginBottom: '6px' }} type="text" value={field.placeholder || ''} onChange={e => updateTemplateField(fi, 'placeholder', e.target.value)} placeholder="Placeholder text (optional)" />
