              style={{ background: T.primaryLight, border: `1px solid ${T.primaryBorder}`, color: T.primary, padding: '3px 8px', borderRadius: '4px', cursor: 'pointer', fontSize: '0.72rem', fontWeight: 700 }}>+ Add Field</button>
          </div>
          <div style={{ display: 'flex', flexDirection: 'column', gap: '8px' }}>
            {(baseConfig.template || []).map((field, fi) => (
