                        onKeyDown={e => { if (e.key === 'Enter') { e.preventDefault(); const val = e.target.value.trim(); if (!val) return; updateTemplateField(fi, 'options', [...(field.options || []), val]); e.target.value = ''; } }} />
                      <button onClick={() => { const input = document.getElementById(`newTplOpt_${baseConfig.id}_${fi}`); const val = input.value.trim(); if (!val) return; updateTemplateField(fi, 'options', [...(field.options || []), val]); input.value = ''; }}
                        style={{ background: T.primaryLight, border: `1px solid ${T.primaryBorder}`, color: T.primary, padding: '5px 10px', borderRadius: '5px', cursor: 'pointer', fontWeight: 700, fontSize: '0.72rem', whiteSpace: 'nowrap' }}>+ Add</button>
                    </div>
                    <div style={{ display: 'flex', flexDirection: 'column', gap: '3px' }}>
                      {(field.options || []).map((opt, oi) => (
