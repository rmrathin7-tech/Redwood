  const renderRepeatingGroupConfigUI = (baseConfig, onChangeConfig) => {
    const updateTemplateField = (fi, key, value) => { const tpl = [...(baseConfig.template || [])]; tpl[fi] = { ...tpl[fi], [key]: value }; onChangeConfig({ template: tpl }); };
